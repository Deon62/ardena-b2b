# Copy this file to .env.local and fill in your values (Vite exposes only
# VITE_-prefixed vars to the client). .env.local is gitignored.

# Backend API base URL (defaults to https://api.ardena.xyz/api/v1/b2b)
VITE_API_BASE_URL=

# Mapbox access token for the live vehicle-tracking map.
# In production this lives in the BACKEND env (MAPBOX_TOKEN) and is served to the
# client via GET /config — see docs/backend-new-modules.md. This VITE_ var is
# only a local-dev fallback for when the /config endpoint isn't up yet.
# Get one free at https://account.mapbox.com/access-tokens/
VITE_MAPBOX_TOKEN=
